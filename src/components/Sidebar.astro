---
/**
 * Custom Sidebar — branded package switcher + redesigned accordion.
 *
 * The package switcher is a fully custom button+popover combobox (NOT a
 * native <select>): branded chrome, grouped sections, keyboard nav,
 * outside-click dismiss. The sidebar tree below uses Starlight's Default
 * sidebar (which already runs the topic-plugin middleware) so all the
 * routing keeps working — we just style the tree heavily via global.css.
 */
import Default from "@astrojs/starlight/components/Sidebar.astro";

const data = Astro.locals.starlightSidebarTopics;
const topics = data?.topics ?? [];

// Groupings reflect dev intent, not alphabetical sort.
const groups = {
  Foundation: ["Core", "Seal", "Logger", "Context", "File System"],
  Data: ["Cascade", "Cache"],
  Lifecycle: ["Auth", "Access", "Scheduler", "Herald", "Notifications"],
  AI: ["AI"],
};

const byLabel = new Map(topics.map((t) => [t.label, t]));
const currentTopic = topics.find((t) => t.isCurrent);

const groupEntries = Object.entries(groups)
  .map(([group, labels]) => ({
    group,
    items: labels.map((l) => byLabel.get(l)).filter(Boolean),
  }))
  .filter((entry) => entry.items.length > 0);

// Tiny inline glyph per package — keeps each row scannable.
const iconFor = (label: string): string => {
  const map: Record<string, string> = {
    Core: "M12 2 2 7l10 5 10-5-10-5Zm0 13L2 10v7l10 5 10-5v-7l-10 5Z",
    Seal: "M9 12l2 2 4-4m6 2a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z",
    Logger: "M4 6h16M4 12h16M4 18h10",
    Context: "M21 11a9 9 0 1 1-9-9 9 9 0 0 1 9 9Zm-9-5v5l3 2",
    "File System": "M3 7a2 2 0 0 1 2-2h4l2 2h8a2 2 0 0 1 2 2v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2Z",
    Cascade: "M4 6a8 3 0 1 0 16 0 8 3 0 1 0-16 0Zm0 0v6c0 1.66 3.58 3 8 3s8-1.34 8-3V6m-16 6v6c0 1.66 3.58 3 8 3s8-1.34 8-3v-6",
    Cache: "M21 12a9 9 0 1 1-9-9m9 9h-9V3",
    Auth: "M12 2 4 6v6c0 5 3.5 9 8 10 4.5-1 8-5 8-10V6Z",
    Access: "M12 2 4 6v6c0 5 3.5 9 8 10 4.5-1 8-5 8-10V6Z M9.5 12l2 2 3.5-4",
    Scheduler: "M12 7v5l3 2m6-2a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z",
    Herald: "M3 11h14l-5-5m5 9h-14l5 5",
    Notifications: "M18 8a6 6 0 0 0-12 0c0 7-3 9-3 9h18s-3-2-3-9Zm-3.5 13a2.5 2.5 0 0 1-5 0",
    AI: "M9 3a2 2 0 0 0-2 2v3H5a2 2 0 0 0-2 2v4a2 2 0 0 0 2 2h2v3a2 2 0 0 0 2 2h6a2 2 0 0 0 2-2v-3h2a2 2 0 0 0 2-2v-4a2 2 0 0 0-2-2h-2V5a2 2 0 0 0-2-2Zm0 7h6m-6 4h6",
  };
  return map[label] ?? "M12 2v20M2 12h20";
};
---

{
  topics.length > 0 && (
    <div class="warlock-pkg" data-pkg-switcher>
      <div class="warlock-pkg-eyebrow">
        <span class="warlock-pkg-eyebrow-dot" aria-hidden="true" />
        Package
      </div>

      <button
        type="button"
        class="warlock-pkg-trigger"
        aria-haspopup="listbox"
        aria-expanded="false"
        aria-controls="warlock-pkg-popover"
        data-pkg-trigger
      >
        <span class="warlock-pkg-trigger-mark" aria-hidden="true">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
            <path d={iconFor(currentTopic?.label ?? "Core")} />
          </svg>
        </span>
        <span class="warlock-pkg-trigger-text">
          <span class="warlock-pkg-trigger-name">
            {currentTopic?.label ?? "Pick a package"}
          </span>
          <span class="warlock-pkg-trigger-sub">
            {currentTopic ? "@warlock.js/" + currentTopic.label.toLowerCase() : "Browse all 13"}
          </span>
        </span>
        <svg class="warlock-pkg-trigger-chevron" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="m6 9 6 6 6-6" />
        </svg>
      </button>

      <div
        id="warlock-pkg-popover"
        class="warlock-pkg-popover"
        role="listbox"
        aria-label="Switch package"
        data-pkg-popover
        hidden
      >
        {groupEntries.map(({ group, items }) => (
          <div class="warlock-pkg-group">
            <div class="warlock-pkg-group-label">{group}</div>
            <ul class="warlock-pkg-list">
              {items.map((topic) => (
                <li>
                  <a
                    role="option"
                    aria-selected={topic.isCurrent ? "true" : "false"}
                    class:list={["warlock-pkg-option", topic.isCurrent && "is-active"]}
                    href={topic.link}
                    data-pkg-option
                  >
                    <span class="warlock-pkg-option-mark" aria-hidden="true">
                      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                        <path d={iconFor(topic.label)} />
                      </svg>
                    </span>
                    <span class="warlock-pkg-option-name">{topic.label}</span>
                    {topic.isCurrent && (
                      <svg class="warlock-pkg-option-check" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <path d="m5 12 5 5L20 7" />
                      </svg>
                    )}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  )
}

<Default><slot /></Default>

<script>
  // Custom dropdown behavior: open/close, outside-click, Escape, arrow keys.
  // Querying inside a function so it works with Astro's view transitions.
  function initPkgSwitcher() {
    const root = document.querySelector<HTMLElement>("[data-pkg-switcher]");
    if (!root || root.dataset.pkgInit === "1") return;
    root.dataset.pkgInit = "1";

    const trigger = root.querySelector<HTMLButtonElement>("[data-pkg-trigger]");
    const popover = root.querySelector<HTMLElement>("[data-pkg-popover]");
    if (!trigger || !popover) return;

    const options = Array.from(popover.querySelectorAll<HTMLAnchorElement>("[data-pkg-option]"));
    let activeIndex = options.findIndex((o) => o.getAttribute("aria-selected") === "true");
    if (activeIndex < 0) activeIndex = 0;

    const open = () => {
      popover.hidden = false;
      trigger.setAttribute("aria-expanded", "true");
      root.classList.add("is-open");
      // Focus active option for keyboard users.
      requestAnimationFrame(() => options[activeIndex]?.focus());
    };

    const close = () => {
      popover.hidden = true;
      trigger.setAttribute("aria-expanded", "false");
      root.classList.remove("is-open");
    };

    const toggle = () => {
      if (popover.hidden) open();
      else close();
    };

    trigger.addEventListener("click", (e) => {
      e.stopPropagation();
      toggle();
    });

    trigger.addEventListener("keydown", (e) => {
      if (e.key === "ArrowDown" || e.key === "Enter" || e.key === " ") {
        e.preventDefault();
        open();
      }
    });

    options.forEach((opt, i) => {
      opt.addEventListener("keydown", (e) => {
        if (e.key === "ArrowDown") {
          e.preventDefault();
          activeIndex = (i + 1) % options.length;
          options[activeIndex].focus();
        } else if (e.key === "ArrowUp") {
          e.preventDefault();
          activeIndex = (i - 1 + options.length) % options.length;
          options[activeIndex].focus();
        } else if (e.key === "Escape") {
          e.preventDefault();
          close();
          trigger.focus();
        } else if (e.key === "Home") {
          e.preventDefault();
          options[0].focus();
        } else if (e.key === "End") {
          e.preventDefault();
          options[options.length - 1].focus();
        }
      });
    });

    document.addEventListener("click", (e) => {
      if (popover.hidden) return;
      if (!root.contains(e.target as Node)) close();
    });

    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && !popover.hidden) {
        close();
        trigger.focus();
      }
    });
  }

  initPkgSwitcher();
  document.addEventListener("astro:page-load", initPkgSwitcher);
</script>
