---
/**
 * Home-page package showcase. Reuses the shared HighlightFeatures grid with a
 * curated subset of the headline packages (the home page shows breadth, not
 * the full catalogue — that's what /packages is for). Ledes/bodies are
 * paraphrased from the authoritative descriptions in packages.mdx.
 *
 * HighlightFeatures has no max-width of its own (it's built for in-content
 * package pages), so we constrain it to the shared 72rem landing width here.
 */
import HighlightFeatures from "./HighlightFeatures.astro";

const packages = [
  {
    icon: "M5 4h14v6H5zM5 14h14v6H5zM8.5 7h.01M8.5 17h.01",
    title: "Core",
    lede: "The HTTP backbone.",
    body: "Routing, modules, middleware, mail, and file storage — with the conventions every Warlock app is built on.",
  },
  {
    icon: "M12 8c4.42 0 8-1.34 8-3s-3.58-3-8-3-8 1.34-8 3 3.58 3 8 3ZM4 5v14c0 1.66 3.58 3 8 3s8-1.34 8-3V5M4 12c0 1.66 3.58 3 8 3s8-1.34 8-3",
    title: "Cascade",
    lede: "Typed database ORM.",
    body: "Models with relations and migrations, atomic operations, and built-in vector search — all fully typed.",
  },
  {
    icon: "M13 2 3 14h7l-1 8 10-12h-7z",
    title: "Cache",
    lede: "Multi-driver caching.",
    body: "Tags, locks, stale-while-revalidate, and similarity search behind one consistent API.",
  },
  {
    icon: "M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10ZM9 12l2 2 4-4",
    title: "Auth & Access",
    lede: "Identity and permissions.",
    body: "Tokens, route protection, and custom user types — plus RBAC checks and ABAC policies when you need them.",
  },
  {
    icon: "M12 22a10 10 0 1 0 0-20 10 10 0 0 0 0 20ZM8.5 12l2.5 2.5 4.5-5",
    title: "Seal",
    lede: "One schema, three jobs.",
    body: "Validation that doubles as TypeScript types and JSON schema — define a shape once and reuse it everywhere.",
  },
  {
    icon: "M12 3l1.8 5.2L19 10l-5.2 1.8L12 17l-1.8-5.2L5 10l5.2-1.8zM5 4v3M3.5 5.5h3M18 16v3M16.5 17.5h3",
    title: "AI",
    lede: "Agents on the same stack.",
    body: "Typed agents, tools, workflows, and supervisors — with five provider adapters behind a single API.",
  },
];
---

<div class="warlock-packages">
  <HighlightFeatures
    kicker="[ What's in the box ]"
    title="A package for every layer"
    subtitle="Independently installable, designed to compose. Here are six of the headline packages."
    features={packages}
  />

  <div class="warlock-packages-foot">
    <a class="warlock-packages-link" href="/packages/">
      Browse all packages
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M5 12h14M13 5l7 7-7 7" />
      </svg>
    </a>
  </div>
</div>

<style>
  .warlock-packages {
    max-width: 72rem;
    margin: 0 auto;
    padding: clamp(1rem, 1rem + 1vw, 2rem) clamp(1.25rem, 4vw, 2.5rem);
  }

  .warlock-packages-foot {
    margin-block-start: 1.75rem;
    text-align: center;
  }

  .warlock-packages-link {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--sl-color-text-accent) !important;
    text-decoration: none !important;
    transition: gap 0.15s ease;
  }

  .warlock-packages-link:hover {
    gap: 0.7rem;
  }
</style>
