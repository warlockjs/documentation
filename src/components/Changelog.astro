---
/**
 * Unified Warlock.js changelog.
 *
 * Renders src/data/changelog.json (generated from each package's CHANGELOG.md +
 * src/data/releases.json). Each release shows: version, date, release notes,
 * then its changes grouped by TYPE — Added / Changed / Fixed / Deprecated /
 * Removed — with every line prefixed by the package it belongs to. A release
 * with no typed changes (the baseline) lists its packages as chips. A package
 * dropdown (modelled on the docs sidebar switcher) + `?package=<slug>` deep link
 * narrows every line to a single package.
 *
 * The page title (H1) comes from Starlight (frontmatter); this component does
 * not render its own. Presentation only — the data is the source of truth.
 */
import data from "../data/changelog.json";

const { packages = [], releases = [] } = data;
const hasContent = releases.length > 0;
---

<div class="cl">
  <div class="cl-toolbar">
    <p class="cl-sub">
      Shipped releases across the <code>@warlock.js/*</code> packages — one shared
      version line, newest first.
    </p>

    {
      hasContent && (
        <div class="cl-filter" data-cl-filter>
          <span class="cl-filter-eyebrow">
            <svg class="cl-filter-funnel" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 4h18l-7 8v7l-4-2v-5L3 4Z" /></svg>
            Filter
          </span>
          <button type="button" class="cl-filter-trigger" aria-haspopup="listbox" aria-expanded="false" aria-controls="cl-filter-popover" data-cl-trigger>
            <span class="cl-filter-current" data-cl-current>All packages</span>
            <svg class="cl-filter-chevron" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m6 9 6 6 6-6" /></svg>
          </button>
          <div id="cl-filter-popover" class="cl-filter-popover" role="listbox" aria-label="Filter changelog by package" data-cl-popover hidden>
            <button type="button" role="option" aria-selected="true" class="cl-filter-option is-active" data-filter="all" data-label="All packages">
              <span class="cl-filter-option-name">All packages</span>
              <svg class="cl-filter-check" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m5 12 5 5L20 7" /></svg>
            </button>
            {packages.map((pkg) => (
              <button type="button" role="option" aria-selected="false" class="cl-filter-option" data-filter={pkg.slug} data-label={pkg.name}>
                <span class="cl-filter-option-name">{pkg.name}</span>
                <svg class="cl-filter-check" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m5 12 5 5L20 7" /></svg>
              </button>
            ))}
          </div>
        </div>
      )
    }
  </div>

  {
    !hasContent && (
      <p class="cl-empty">
        No shipped releases yet. Add a version entry to
        <code>src/data/releases.json</code> + the changes to a package's
        <code>CHANGELOG.md</code>, then run <code>yarn sync:changelog</code>.
      </p>
    )
  }

  <div class="cl-list">
    {
      releases.map((rel, i) => (
        <details class="cl-rel" data-release={rel.id} open={i === 0}>
          <summary class="cl-rel-head" id={rel.id}>
            <div class="cl-rel-ver" role="heading" aria-level="2">
              <span class="cl-rel-tick" aria-hidden="true" />
              {rel.version}
            </div>
            {rel.date && (
              <span class="cl-rel-date">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <rect x="3" y="4" width="18" height="18" rx="2" /><path d="M16 2v4M8 2v4M3 10h18" />
                </svg>
                {rel.date}
              </span>
            )}
            <svg class="cl-rel-chevron" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="m6 9 6 6 6-6" />
            </svg>
          </summary>

          <div class="cl-rel-body">
            {rel.summaryHtml && <p class="cl-rel-summary" set:html={rel.summaryHtml} />}

            {rel.mode === "detail" &&
              rel.packages.map((pkg) => {
                const slash = pkg.name.lastIndexOf("/");
                const scope = slash === -1 ? "" : pkg.name.slice(0, slash + 1);
                const name = slash === -1 ? pkg.name : pkg.name.slice(slash + 1);
                return (
                  <div class="cl-pkg" data-changelog-package={pkg.slug}>
                    <div class="cl-pkg-head">
                      <span class="cl-pkg-name" role="heading" aria-level="3"
                        >{scope && <span class="cl-pkg-scope">{scope}</span>}{name}</span
                      >
                      <span class="cl-pkg-counts">
                        {pkg.counts.map((c) => (
                          <span class="cl-pkg-count" data-type={c.type}>
                            {c.type} <b>{c.n}</b>
                          </span>
                        ))}
                      </span>
                    </div>
                    <ul class="cl-pkg-items">
                      {pkg.items.map((it) => (
                        <li class="cl-line" data-type={it.type}>
                          <span class="cl-line-type">{it.type}</span>
                          <span class="cl-line-text" set:html={it.html} />
                        </li>
                      ))}
                    </ul>
                  </div>
                );
              })}
          </div>
        </details>
      ))
    }
  </div>

  <p class="cl-empty cl-no-match" data-cl-empty hidden>No changes recorded for this package yet.</p>
</div>

<script>
  // Package filter (button + popover, modelled on the sidebar switcher) + the
  // `?package=<slug>` deep link. Every change line and chip carries
  // `data-changelog-package`, so the filter toggles by attribute and collapses
  // any section / release left empty.
  function initChangelog() {
    const root = document.querySelector<HTMLElement>("[data-cl-filter]");
    if (!root || root.dataset.clInit === "1") return;
    root.dataset.clInit = "1";

    const trigger = root.querySelector<HTMLButtonElement>("[data-cl-trigger]");
    const popover = root.querySelector<HTMLElement>("[data-cl-popover]");
    const current = root.querySelector<HTMLElement>("[data-cl-current]");
    if (!trigger || !popover || !current) return;

    const options = Array.from(popover.querySelectorAll<HTMLButtonElement>("[data-filter]"));
    // Package blocks (each carries data-changelog-package) — the filter unit.
    const blocks = Array.from(document.querySelectorAll<HTMLElement>("[data-changelog-package]"));
    const releases = Array.from(document.querySelectorAll<HTMLDetailsElement>(".cl-rel"));
    const empty = document.querySelector<HTMLElement>("[data-cl-empty]");
    let activeIndex = 0;

    const open = () => {
      popover.hidden = false;
      trigger.setAttribute("aria-expanded", "true");
      root.classList.add("is-open");
      requestAnimationFrame(() => options[activeIndex]?.focus());
    };
    const close = () => {
      popover.hidden = true;
      trigger.setAttribute("aria-expanded", "false");
      root.classList.remove("is-open");
    };
    const toggle = () => (popover.hidden ? open() : close());

    function applyFilter(slug: string, label: string) {
      current.textContent = label;
      options.forEach((o, i) => {
        const on = o.dataset.filter === slug;
        o.classList.toggle("is-active", on);
        o.setAttribute("aria-selected", on ? "true" : "false");
        if (on) activeIndex = i;
      });

      let total = 0;
      blocks.forEach((b) => {
        const match = slug === "all" || b.dataset.changelogPackage === slug;
        b.hidden = !match;
        if (match) total++;
      });
      releases.forEach((rel, i) => {
        const any = Array.from(rel.querySelectorAll<HTMLElement>("[data-changelog-package]")).some((b) => !b.hidden);
        rel.hidden = !any;
        // Default: only the newest release open. While filtering: open every
        // release that still has a match so the results are visible.
        rel.open = slug === "all" ? i === 0 : any;
      });
      if (empty) empty.hidden = total > 0;

      const url = new URL(window.location.href);
      if (slug === "all") url.searchParams.delete("package");
      else url.searchParams.set("package", slug);
      window.history.replaceState(null, "", url);
    }

    options.forEach((opt, i) => {
      opt.addEventListener("click", () => {
        applyFilter(opt.dataset.filter || "all", opt.dataset.label || "All packages");
        close();
        trigger.focus();
      });
      opt.addEventListener("keydown", (e) => {
        if (e.key === "ArrowDown") {
          e.preventDefault();
          options[(i + 1) % options.length].focus();
        } else if (e.key === "ArrowUp") {
          e.preventDefault();
          options[(i - 1 + options.length) % options.length].focus();
        } else if (e.key === "Escape") {
          e.preventDefault();
          close();
          trigger.focus();
        }
      });
    });

    document.querySelectorAll<HTMLButtonElement>("[data-chip]").forEach((chip) => {
      chip.addEventListener("click", () => {
        const slug = chip.dataset.chip || "all";
        const opt = options.find((o) => o.dataset.filter === slug);
        applyFilter(slug, opt?.dataset.label || slug);
        window.scrollTo({ top: 0, behavior: "smooth" });
      });
    });

    trigger.addEventListener("click", (e) => {
      e.stopPropagation();
      toggle();
    });
    trigger.addEventListener("keydown", (e) => {
      if (e.key === "ArrowDown" || e.key === "Enter" || e.key === " ") {
        e.preventDefault();
        open();
      }
    });

    document.addEventListener("click", (e) => {
      if (!popover.hidden && !root.contains(e.target as Node)) close();
    });
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && !popover.hidden) {
        close();
        trigger.focus();
      }
    });

    const initial = new URLSearchParams(window.location.search).get("package");
    const match = options.find((o) => o.dataset.filter === initial);
    if (match) applyFilter(match.dataset.filter || "all", match.dataset.label || "All packages");
  }

  initChangelog();
  document.addEventListener("astro:page-load", initChangelog);
</script>

<style>
  .cl {
    --cl-added: #3fb950;
    --cl-changed: #d29922;
    --cl-fixed: #539bf5;
    --cl-deprecated: #db6d28;
    --cl-removed: #f85149;
    --cl-security: #bc8cff;
    --cl-new: #c66bff;
    --cl-breaking: #f85149;

    max-width: 50rem;
    margin-inline: auto;
    text-align: start;
  }

  /* ---- Toolbar ---- */
  .cl-toolbar {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 1.5rem;
    flex-wrap: wrap;
    margin: 0.25rem 0 2.5rem;
    padding-bottom: 1.25rem;
    border-bottom: 1px solid var(--sl-color-hairline);
  }
  .cl-sub {
    margin: 0;
    max-width: 30rem;
    color: var(--sl-color-gray-2);
    font-size: 0.98rem;
    line-height: 1.6;
  }
  .cl-sub code { font-family: var(--sl-font-mono); font-size: 0.85em; }

  /* ---- Filter dropdown (mirrors the sidebar package switcher) ---- */
  .cl-filter { position: relative; flex: 0 0 auto; min-width: 15rem; }
  .cl-filter-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    margin-bottom: 0.4rem;
    font-size: 0.66rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--sl-color-gray-3, var(--sl-color-gray-2));
  }
  .cl-filter-funnel { color: var(--sl-color-text-accent); }
  .cl-filter-trigger {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    width: 100%;
    cursor: pointer;
    padding: 0.6rem 0.8rem;
    border-radius: var(--warlock-radius, 0.6rem);
    border: 1px solid var(--sl-color-hairline);
    background: var(--warlock-surface-dark, var(--sl-color-black));
    color: var(--sl-color-white);
    font-family: var(--sl-font-mono);
    font-size: 0.85rem;
    text-align: start;
    transition: border-color 0.18s ease;
  }
  .cl-filter-trigger:hover,
  .cl-filter.is-open .cl-filter-trigger { border-color: var(--sl-color-text-accent); }
  .cl-filter-trigger:focus-visible { outline: 2px solid var(--sl-color-text-accent); outline-offset: 2px; }
  .cl-filter-current { flex: 1 1 auto; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .cl-filter-chevron { flex: 0 0 auto; color: var(--sl-color-gray-2); transition: transform 0.2s ease; }
  .cl-filter.is-open .cl-filter-chevron { transform: rotate(180deg); }
  .cl-filter-popover {
    position: absolute;
    z-index: 30;
    top: calc(100% + 0.4rem);
    inset-inline: 0;
    max-height: 21rem;
    overflow-y: auto;
    padding: 0.4rem;
    border-radius: var(--warlock-radius, 0.6rem);
    border: 1px solid var(--sl-color-hairline);
    background: var(--sl-color-bg-nav, var(--sl-color-black));
    box-shadow: 0 16px 40px -12px rgba(0, 0, 0, 0.55);
  }
  .cl-filter-option {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    width: 100%;
    cursor: pointer;
    padding: 0.5rem 0.6rem;
    border: 0;
    border-radius: var(--warlock-radius-sm, 0.4rem);
    background: transparent;
    color: var(--sl-color-gray-1, var(--sl-color-white));
    font-family: var(--sl-font-mono);
    font-size: 0.82rem;
    text-align: start;
    transition: background-color 0.15s ease, color 0.15s ease;
  }
  .cl-filter-option-name { flex: 1 1 auto; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .cl-filter-option:hover,
  .cl-filter-option:focus-visible {
    background: color-mix(in srgb, var(--sl-color-text-accent) 10%, transparent);
    color: var(--sl-color-white);
    outline: none;
  }
  .cl-filter-option.is-active { color: var(--sl-color-text-accent); }
  .cl-filter-check { flex: 0 0 auto; opacity: 0; color: var(--sl-color-text-accent); }
  .cl-filter-option.is-active .cl-filter-check { opacity: 1; }

  /* ---- Release (accordion) ---- */
  .cl-list { display: flex; flex-direction: column; }
  .cl-rel {
    scroll-margin-top: 5rem;
    border-top: 1px solid var(--sl-color-hairline);
  }
  .cl-rel:last-child { border-bottom: 1px solid var(--sl-color-hairline); }

  .cl-rel-head {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
    cursor: pointer;
    list-style: none;
    padding: 1.05rem 0;
  }
  .cl-rel-head::-webkit-details-marker { display: none; }
  .cl-rel-head::marker { content: ""; display: none; }
  /* Belt-and-braces: hide whatever Starlight's global summary styling adds. */
  details.cl-rel > summary { list-style: none !important; }
  details.cl-rel > summary::before { content: none !important; }
  .cl-rel-head:focus-visible {
    outline: 2px solid var(--sl-color-text-accent);
    outline-offset: -2px;
    border-radius: 0.4rem;
  }
  .cl-rel-chevron {
    flex: 0 0 auto;
    color: var(--sl-color-gray-2);
    transition: transform 0.2s ease;
  }
  .cl-rel[open] .cl-rel-chevron { transform: rotate(180deg); }
  .cl-rel-body { padding: 0.35rem 0 1.85rem; }
  .cl-rel-ver {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    margin: 0;
    font-family: var(--sl-font-mono);
    font-size: 1.5rem;
    font-weight: 700;
    line-height: 1;
    color: var(--sl-color-white);
  }
  .cl-rel-tick {
    width: 9px;
    height: 9px;
    border-radius: 50%;
    background: var(--sl-color-text-accent);
    box-shadow: 0 0 0 4px color-mix(in srgb, var(--sl-color-text-accent) 18%, transparent);
  }
  .cl-rel-date {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    margin-inline-start: auto;
    padding: 0.32rem 0.7rem;
    border-radius: 999px;
    border: 1px solid var(--sl-color-hairline);
    background: var(--warlock-surface-dark, transparent);
    font-family: var(--sl-font-mono);
    font-size: 0.82rem;
    font-variant-numeric: tabular-nums;
    color: var(--sl-color-gray-1, var(--sl-color-white));
  }
  .cl-rel-date svg { color: var(--sl-color-text-accent); }

  .cl-rel-summary {
    /* Treat the summary as a calmer lede so it doesn't compete with the
       sections below — slightly smaller, dimmer, and divided by a hairline
       so the eye knows where the bullet stream begins. */
    margin: 0 0 0;
    padding-bottom: 1.6rem;
    border-bottom: 1px solid var(--sl-color-hairline);
    color: var(--sl-color-gray-2);
    font-size: 0.98rem;
    line-height: 1.7;
    max-width: 44rem;
  }
  .cl-rel-summary :global(code) {
    font-family: var(--sl-font-mono);
    font-size: 0.86em;
    padding: 0.05em 0.32em;
    border-radius: 0.25em;
    /* Same Starlight specificity issue as .cl-line-text code. */
    background: color-mix(in srgb, var(--sl-color-text-accent) 6%, transparent) !important;
    color: color-mix(in srgb, var(--sl-color-text-accent) 78%, white) !important;
  }
  .cl-rel-summary :global(strong) { color: var(--sl-color-white); font-weight: 600; }

  /* Per-type colours, set on each line / count via [data-type]. */
  [data-type="⚠ BREAKING"] { --_c: var(--cl-breaking); }
  [data-type="New"] { --_c: var(--cl-new); }
  [data-type="Added"] { --_c: var(--cl-added); }
  [data-type="Changed"] { --_c: var(--cl-changed); }
  [data-type="Fixed"] { --_c: var(--cl-fixed); }
  [data-type="Deprecated"] { --_c: var(--cl-deprecated); }
  [data-type="Removed"] { --_c: var(--cl-removed); }
  [data-type="Security"] { --_c: var(--cl-security); }

  /* ---- Per-package block ---- */
  .cl-pkg { padding: 1.6rem 0; }
  .cl-pkg:first-of-type { padding-top: 1.8rem; }
  .cl-pkg + .cl-pkg { border-top: 1px solid var(--sl-color-hairline); }

  .cl-pkg-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.75rem 1.25rem;
    flex-wrap: wrap;
    margin-bottom: 1.1rem;
  }
  .cl-pkg-name {
    font-family: var(--sl-font-mono);
    font-weight: 700;
    font-size: 1.02rem;
    color: var(--sl-color-white);
  }
  .cl-pkg-scope { color: var(--sl-color-gray-3, var(--sl-color-gray-2)); font-weight: 400; }

  .cl-pkg-counts { display: flex; flex-wrap: wrap; gap: 0.4rem; }
  .cl-pkg-count {
    font-family: var(--sl-font-mono);
    font-size: 0.68rem;
    font-weight: 500;
    letter-spacing: 0.02em;
    padding: 0.18em 0.55em;
    border-radius: 999px;
    color: color-mix(in srgb, var(--_c, var(--sl-color-gray-2)) 85%, white);
    background: color-mix(in srgb, var(--_c, var(--sl-color-gray-2)) 11%, transparent);
  }
  .cl-pkg-count b { font-weight: 700; font-variant-numeric: tabular-nums; }

  /* ---- One change line: [type] + text, type-coloured ---- */
  .cl-pkg-items {
    margin: 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
  }
  .cl-line {
    display: grid;
    grid-template-columns: 5.25rem 1fr;
    gap: 0.85rem;
    align-items: baseline;
    line-height: 1.7;
    font-size: 0.93rem;
    color: var(--sl-color-gray-1, var(--sl-color-white));
  }
  .cl-line-type {
    justify-self: start;
    font-family: var(--sl-font-mono);
    font-size: 0.66rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 0.22em 0.55em;
    border-radius: 0.35em;
    color: var(--_c, var(--sl-color-gray-2));
    background: color-mix(in srgb, var(--_c, var(--sl-color-gray-2)) 13%, transparent);
    white-space: nowrap;
  }

  /* `New` — a brand-new package's debut. The label TEXT is a shiny, flowing
     holographic rainbow (the gradient is clipped to the glyphs, not the
     background), distinct from every solid type colour. It drifts on a loop and
     freezes under prefers-reduced-motion; a faint pill sits behind it. */
  [data-type="New"] .cl-line-type {
    font-weight: 800;
    background: linear-gradient(
      110deg,
      #ff6b9d,
      #c66bff,
      #6b9dff,
      #4ade80,
      #ffd56b,
      #ff6b9d
    );
    background-size: 280% 100%;
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    color: transparent;
    animation: cl-new-rainbow 7s linear infinite;
    /* The `background` drives the text gradient, so the pill fill + ring come
       from box-shadow (inset spread fills the rounded box behind the glyphs). */
    box-shadow:
      inset 0 0 0 999px color-mix(in srgb, var(--cl-new) 9%, transparent),
      0 0 0 1px color-mix(in srgb, var(--cl-new) 22%, transparent);
  }
  @keyframes cl-new-rainbow {
    0% { background-position: 0% 50%; }
    100% { background-position: 280% 50%; }
  }
  @media (prefers-reduced-motion: reduce) {
    [data-type="New"] .cl-line-type { animation: none; }
  }

  .cl-line-text :global(strong) { color: var(--sl-color-white); font-weight: 650; }
  .cl-line-text :global(code) {
    font-family: var(--sl-font-mono);
    font-size: 0.86em;
    padding: 0.05em 0.32em;
    border-radius: 0.25em;
    /* Calmer chip — much lower yellow saturation. !important because
       Starlight's `.sl-markdown-content :not(pre) > code` outranks the
       Astro-scoped `:where(...)` selector this component uses. */
    background: color-mix(in srgb, var(--sl-color-text-accent) 5%, transparent) !important;
    color: color-mix(in srgb, var(--sl-color-text-accent) 78%, white) !important;
  }

  @media (max-width: 38rem) {
    .cl-line { grid-template-columns: 1fr; gap: 0.3rem; }
  }

  /* ---- Compact: package chips (baseline) ---- */
  .cl-chips-wrap { display: flex; flex-direction: column; gap: 0.7rem; }
  .cl-chips-label {
    font-size: 0.68rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.09em;
