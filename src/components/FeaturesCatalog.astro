      { name: "Observability", blurb: "Trace every run and export to OpenTelemetry or Langfuse.", href: `${base}/ai/observability/ai-panoptic/`, tag: "Panoptic", icon: "M2 12s3.5-7 10-7 10 7 10 7-3.5 7-10 7-10-7-10-7ZM12 15a3 3 0 1 0 0-6 3 3 0 0 0 0 6Z" },
      { name: "Provider adapters", blurb: "Swap between providers without touching agent code.", href: `${base}/ai/`, tag: "5 providers", icon: "M9 2v6M15 2v6M6 8h12v3a6 6 0 0 1-12 0zM12 17v5" },
