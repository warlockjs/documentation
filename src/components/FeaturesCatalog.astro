      { name: "Authorization", blurb: "Permission checks, policies, and roles.", href: `${base}/access/`, tag: "RBAC · ABAC", icon: "M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10ZM9 12l2 2 4-4" },
    ],
  },
  {
    label: "Platform & DX",
    tagline: "The operational backbone.",
    accent: "#2DD4BF",
    icon: "m4 17 6-6-6-6M12 19h8",
    features: [
      { name: "Scheduler", blurb: "Cron jobs with retry, overlap prevention, and timezones.", href: `${base}/scheduler/`, icon: "M8 2v4M16 2v4M3 10h18M5 4h14a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2z" },
      { name: "Structured logging", blurb: "Channels, redaction, and shutdown flushing.", href: `${base}/logger/`, icon: "M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8zM14 2v6h6M9 13h6M9 17h6" },
      { name: "Typed schemas", blurb: "Validation that doubles as types and JSON schema.", href: `${base}/seal/`, tag: "Seal", icon: "M7 3H6a2 2 0 0 0-2 2v4a2 2 0 0 1-2 2 2 2 0 0 1 2 2v4a2 2 0 0 0 2 2h1M17 3h1a2 2 0 0 1 2 2v4a2 2 0 0 0 2 2 2 2 0 0 0-2 2v4a2 2 0 0 1-2 2h-1" },
      { name: "Request context", blurb: "Request-scoped context without prop-drilling.", href: `${base}/context/`, icon: "M18 8a3 3 0 1 0 0-6 3 3 0 0 0 0 6ZM6 15a3 3 0 1 0 0 6 3 3 0 0 0 0-6ZM18 17a3 3 0 1 0 0 6 3 3 0 0 0 0-6ZM8.6 13.5l6.8 4M15.4 6.5 8.6 10.5" },
      { name: "Encryption", blurb: "Built-in encryption helpers.", href: `${base}/core/digging-deeper/encryption/`, icon: "M5 11h14a2 2 0 0 1 2 2v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-7a2 2 0 0 1 2-2zM7 11V7a5 5 0 0 1 10 0v4" },
      { name: "CLI & generators", blurb: "Scaffold modules, commands, and connectors.", href: `${base}/core/cli/generators/`, icon: "m4 17 6-6-6-6M12 19h8" },
      { name: "Testing", blurb: "Per-worker database and cache isolation.", href: `${base}/core/testing/testing/`, tag: "Vitest", icon: "M9 3h6M10 3v6L4.5 18a2 2 0 0 0 1.7 3h11.6a2 2 0 0 0 1.7-3L14 9V3M8 14h8" },
      { name: "Configuration", blurb: "Typed, layered application configuration.", href: `${base}/core/architecture-concepts/configuration-deep/`, icon: "M4 21v-7M4 10V3M12 21v-9M12 8V3M20 21v-5M20 12V3M2 14h4M10 8h4M18 16h4" },
    ],
  },
];
---

<section class="warlock-features not-content">
  <div class="warlock-section-head warlock-features-head">
    <h1 class="warlock-section-title">Everything Warlock ships</h1>
    <p class="warlock-section-sub">
      One framework, batteries included — from HTTP and real-time sockets to a
      MongoDB/Postgres ORM, S3 storage, a message bus, and a typed AI layer.
      Every capability links to its docs.
    </p>
  </div>

  {groups.map((group) => (
    <div class="warlock-features-group" style={`--feat-accent: ${group.accent};`}>
      <div class="warlock-features-rail">
        <span class="warlock-features-groupicon" aria-hidden="true">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d={group.icon} />
          </svg>
        </span>
        <h2 class="warlock-features-grouplabel">{group.label}</h2>
        <p class="warlock-features-grouptagline">{group.tagline}</p>
        <p class="warlock-features-groupcount">{group.features.length} capabilities</p>
      </div>

      <div class="warlock-features-grid">
        {group.features.map((f, i) => (
          <a class="warlock-feature" href={f.href}>
            <span class="warlock-feature-rule" aria-hidden="true"></span>
            <span class="warlock-feature-corner" aria-hidden="true">
              <span class="warlock-feature-index">{String(i + 1).padStart(2, "0")}</span>
              <svg class="warlock-feature-arrow" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M5 12h14M13 5l7 7-7 7" />
              </svg>
            </span>
            <span class="warlock-feature-icon" aria-hidden="true">
              <svg width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d={f.icon} />
              </svg>
            </span>
            <span class="warlock-feature-top">
              <span class="warlock-feature-name">{f.name}</span>
              {f.tag && <span class="warlock-feature-tag">{f.tag}</span>}
            </span>
            <span class="warlock-feature-blurb">{f.blurb}</span>
          </a>
        ))}
      </div>
    </div>
  ))}
</section>

<style>
  .warlock-features {
    max-width: 72rem;
    margin: 0 auto;
    /* Top padding clears the 64px fixed header (the page is full-bleed, so
     * there's no normal content offset) plus breathing room. */
    padding: clamp(6rem, 4rem + 4vw, 8.5rem) clamp(1.25rem, 4vw, 2.5rem) clamp(3rem, 4rem + 2vw, 5rem);
  }

  .warlock-features-head {
    margin-block-end: clamp(2.75rem, 2rem + 2.5vw, 4rem);
  }

  /* ---------- One row per category: rail + card grid ---------- */
  .warlock-features-group {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
    /* Top divider on every category — incl. the first, so a full-width line
     * separates the page header + description from the catalogue. */
    padding-block-start: clamp(2.75rem, 2rem + 2.5vw, 4rem);
    border-top: 1px solid var(--sl-color-hairline);
  }

  @media (min-width: 56rem) {
    .warlock-features-group {
      grid-template-columns: 15rem 1fr;
      gap: 2.5rem;
      align-items: start;
    }
  }

  .warlock-features-group + .warlock-features-group {
    margin-block-start: clamp(2.5rem, 2rem + 2vw, 3.75rem);
  }

  /* ---------- Rail ---------- */
  .warlock-features-rail {
    display: grid;
    grid-template-columns: auto 1fr;
    align-items: center;
    column-gap: 0.75rem;
    row-gap: 0.35rem;
  }

  @media (min-width: 56rem) {
    .warlock-features-rail {
      position: sticky;
      top: 6rem;
      grid-template-columns: 1fr;
      align-items: start;
    }
  }

  .warlock-features-groupicon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 42px;
    height: 42px;
    border-radius: var(--warlock-radius);
    border: 1px solid color-mix(in srgb, var(--feat-accent) 32%, var(--sl-color-hairline));
    background:
      linear-gradient(180deg, color-mix(in srgb, var(--feat-accent) 18%, transparent), color-mix(in srgb, var(--feat-accent) 8%, transparent));
    color: var(--feat-accent);
    box-shadow: 0 0 24px -8px color-mix(in srgb, var(--feat-accent) 75%, transparent);
    flex: none;
  }

  @media (min-width: 56rem) {
    .warlock-features-groupicon {
      margin-block-end: 0.9rem;
    }
  }

  .warlock-features-grouplabel {
    margin: 0;
    font-size: 1.2rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.15;
    color: var(--sl-color-white);
  }

  .warlock-features-grouptagline {
    grid-column: 2;
    margin: 0;
    font-size: 0.88rem;
    line-height: 1.45;
    color: var(--sl-color-gray-3);
  }

  @media (min-width: 56rem) {
    .warlock-features-grouptagline {
      grid-column: auto;
      margin-block-start: 0.4rem;
    }
  }

  .warlock-features-groupcount {
    grid-column: 2;
    margin: 0;
    font-family: var(--sl-font-mono);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--sl-color-gray-4);
  }

  @media (min-width: 56rem) {
    .warlock-features-groupcount {
      grid-column: auto;
      margin-block-start: 0.85rem;
      padding-block-start: 0.85rem;
      border-top: 1px solid var(--sl-color-hairline);
    }
  }

  /* ---------- Card grid ---------- */
  .warlock-features-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.9rem;
  }

  @media (max-width: 30rem) {
    .warlock-features-grid {
      grid-template-columns: 1fr;
    }
  }

  /* Defensive: if a group ever has an odd count, the last card spans full
   * width instead of leaving a gap. */
  .warlock-features-grid > .warlock-feature:last-child:nth-child(odd) {
    grid-column: 1 / -1;
  }

  .warlock-feature {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
    padding: 1.3rem 1.35rem 1.35rem;
    border: 1px solid var(--sl-color-hairline);
    border-radius: var(--warlock-radius);
    background: var(--warlock-surface-dark);
    text-decoration: none !important;
    overflow: hidden;
    transition: border-color 0.18s ease, transform 0.18s ease, box-shadow 0.18s ease, background 0.18s ease;
  }

  :root[data-theme="light"] .warlock-feature {
    background: #ffffff;
  }

  .warlock-feature:hover {
    border-color: color-mix(in srgb, var(--feat-accent) 55%, var(--sl-color-hairline));
    transform: translateY(-3px);
    background:
      radial-gradient(120% 90% at 0% 0%, color-mix(in srgb, var(--feat-accent) 10%, transparent), transparent 55%),
      var(--warlock-surface-dark);
    box-shadow: 0 18px 40px -24px color-mix(in srgb, var(--feat-accent) 75%, transparent);
  }

  :root[data-theme="light"] .warlock-feature:hover {
    background:
      radial-gradient(120% 90% at 0% 0%, color-mix(in srgb, var(--feat-accent) 14%, transparent), transparent 55%),
      #ffffff;
  }

  /* Top accent line — sweeps in on hover (echoes the PathPicker cards) */
  .warlock-feature-rule {
    position: absolute;
    inset-block-start: 0;
    inset-inline: 1.1rem;
    height: 2px;
    background: linear-gradient(90deg, transparent, var(--feat-accent), transparent);
    opacity: 0;
    transform: scaleX(0.4);
    transition: opacity 0.22s ease, transform 0.22s ease;
  }

  .warlock-feature:hover .warlock-feature-rule {
    opacity: 1;
    transform: scaleX(1);
  }

  /* Icon badge — the card's spot of category colour */
  .warlock-feature-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
