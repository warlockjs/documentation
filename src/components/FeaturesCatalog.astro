---
/**
 * Capability catalogue for the /features page.
 *
 * Layout: one row per category — a sticky "rail" on the left (icon, name,
 * tagline, count) and a 2-column card grid on the right. Each category carries
 * its own accent colour (set as `--feat-accent` on the group); cards stay calm
 * at rest (neutral surface, colour only in the small icon badge) and light up
 * with the category colour on hover — colour as a categorisation cue, not a
 * wash over the whole page. Counts are kept even so the 2-column grid never
 * orphans; a defensive rule spans a trailing odd card full-width.
 *
 * Every claim is grounded in the package docs (verified routes) and the
 * scaffolder's feature manifest (create-warlock/src/features/features-map.ts).
 * `not-content` keeps Starlight's markdown auto-flow margin off the grids.
 */
const base = "/v/latest";

interface Feature {
  name: string;
  blurb: string;
  href: string;
  /** Single SVG path, 24x24 viewBox, stroked. */
  icon: string;
  /** Optional tech badge — the concrete answer to "does it support X?". */
  tag?: string;
}

interface Group {
  /** Single SVG path drawn at a 24x24 viewBox. */
  icon: string;
  label: string;
  tagline: string;
  /** Category accent colour (hex). Yellow stays the page-level brand. */
  accent: string;
  features: Feature[];
}

const groups: Group[] = [
  {
    label: "HTTP & API",
    tagline: "The request layer.",
    accent: "#FACC15",
    icon: "M3 12h18M12 3a15 15 0 0 1 4 9 15 15 0 0 1-4 9 15 15 0 0 1-4-9 15 15 0 0 1 4-9Z",
