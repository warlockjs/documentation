      { name: "Orchestrators", blurb: "Stateful multi-turn sessions with durable state, resume, and compaction.", href: `${base}/ai/architecture-concepts/orchestrators/`, tag: "Sessions", icon: "M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z" },
