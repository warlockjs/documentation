      { name: "Validation", blurb: "Request validation backed by Seal schemas.", href: `${base}/core/the-basics/validation/`, icon: "M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10ZM9 12l2 2 4-4" },
      { name: "RESTful resources", blurb: "Resource controllers and typed API resources.", href: `${base}/core/the-basics/restful/`, icon: "M3 3h7v7H3zM14 3h7v7h-7zM14 14h7v7h-7zM3 14h7v7H3z" },
      { name: "Rate limiting", blurb: "Throttle routes out of the box.", href: `${base}/core/recipes/rate-limiting/`, icon: "M12 14a2 2 0 1 0 0-4 2 2 0 0 0 0 4ZM13.4 12.6 16 10M5 20a9 9 0 1 1 14 0" },
      { name: "Modules & conventions", blurb: "Feature modules with batteries-included structure.", href: `${base}/core/getting-started/05-project-layout/`, icon: "m12 2 9 5v10l-9 5-9-5V7zM3.3 7 12 12l8.7-5M12 22V12" },
    ],
  },
